{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "echo 'no build step'",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "{index.html,slides/**,fixtures/**,notso_style_prompt.js,post_process.py,generate.py,zip_assetpack.py,generate_html.js,notso_style_lock.md}",
        "memory": 1024,
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
