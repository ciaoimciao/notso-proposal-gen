# Copy this file to `.env` and fill in real values. DO NOT commit `.env`.
# On Vercel, set these same values in Project Settings → Environment Variables.

# ─── Google Slides OAuth ────────────────────────────
# Create in Google Cloud Console → APIs & Services → Credentials
#   Type: "OAuth 2.0 Client ID" → "Web application"
# Enable these APIs:  Google Slides API,  Google Drive API
# Authorized redirect URIs:
#   http://127.0.0.1:8080        (for local dev)
#   https://<your-project>.vercel.app   (for production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match one of the authorized redirect URIs.
GOOGLE_REDIRECT_URI=http://127.0.0.1:8080

# ─── Optional ───────────────────────────────────────
# If you want the server to ship a default Claude / Gemini key instead of
# asking the user to paste one, set these. Otherwise leave blank.
# CLAUDE_API_KEY=
# GEMINI_API_KEY=
